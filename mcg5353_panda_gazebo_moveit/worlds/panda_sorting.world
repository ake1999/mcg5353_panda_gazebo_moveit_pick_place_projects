      </link>
    </model>

    <model name="sorting_table">
      <static>true</static>
      <pose>0.55 0 0.005 0 0 0</pose>
      <link name="top">
        <visual name="visual">
          <geometry>
            <box>
              <size>0.95 1.25 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry>

<?xml version="1.0"?>
<sdf version="1.6">
  <world name="panda_sorting_world">
    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>100</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>0.01</contact_max_correcting_vel>
          <contact_surface_layer>0.003</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <model name="red_container">
      <static>true</static>
      <pose>0.62 0.48 0.025 0 0 0</pose>
      <link name="base">
        <visual name="visual">
          <geometry>
            <box>
              <size>0.34 0.24 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.05 0.05 1</ambient>
            <diffuse>0.8 0.05 0.05 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.34 0.24 0.05</size>
            </box>
          </geometry>
        </collision>
      </link>
    </model>


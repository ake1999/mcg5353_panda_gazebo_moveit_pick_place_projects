            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>5.0</mu>
                <mu2>5.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>
    </model>

    <model name="red_box_1">
      <pose>0.38 0.12 0.055 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.15</mass>
          <inertia>
            <ixx>0.0000083</ixx>
            <iyy>0.0000083</iyy>
            <izz>0.0000083</izz>
          </inertia>
        </inertial>

        <velocity_decay>
          <linear>0.05</linear>
          <angular>0.05</angular>
        </velocity_decay>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.05 0.05 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.05 0.05 0.05</size>
            </box>
          </geometry>
            <surface>
              <friction>
                <ode>
                  <mu>100.0</mu>
                  <mu2>100.0</mu2>
                  <slip1>0.0</slip1>
                  <slip2>0.0</slip2>
                </ode>
              </friction>
              <contact>
                <ode>
                  <kp>100000.0</kp>
                  <kd>10.0</kd>
                  <max_vel>0.1</max_vel>
                  <min_depth>0.001</min_depth>
                </ode>
              </contact>
              <bounce>
                <restitution_coefficient>0.0</restitution_coefficient>
                <threshold>100000.0</threshold>
              </bounce>
            </surface>
        </collision>
      </link>
    </model>

